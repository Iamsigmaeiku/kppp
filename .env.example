# Decoder TCP source (USR-W610)
# 單一 decoder 用 DECODER_HOST/DECODER_PORT（搭配下面 Writer settings 的
# DECODER_ID）。多台 decoder（例如同一起跑線硬體備援）改用 DECODERS，
# 格式 host:port:decoder_id 逗號分隔，設定後會取代 DECODER_HOST/PORT/ID：
# DECODERS=10.10.100.254:8899:decoder-01,10.10.100.253:8899:decoder-02
#
# 本機（與 W610 同 LAN）：用 W610 的區網 IP，延遲最低
# 遠端 tailnet 裝置：用 MagicDNS（需先在 Windows 閘道跑 scripts/setup-tailscale-w610.ps1）
# DECODER_HOST=usrw610.tail227cf2.ts.net
DECODER_HOST=10.10.100.254
DECODER_PORT=8899

# Reconnect backoff
RECONNECT_INITIAL_SEC=1
RECONNECT_MAX_SEC=30

# InfluxDB — 請指向樹莓派（不要用 Windows localhost Docker）
INFLUX_URL=http://192.168.0.105:8086
INFLUX_TOKEN=kpp-dev-influx-token-change-me
INFLUX_ORG=kpp
INFLUX_BUCKET=decoder

# ESP32 → POST /api/telemetry/ingest 的 Bearer token（勿提交真實值）
TELEMETRY_INGEST_TOKEN=kpp-telemetry-ingest-token-change-me
# Grafana 在 Pi 上；公開站反代後可改相對路徑 /grafana/...
GRAFANA_EMBED_URL=http://192.168.0.105:3000/grafana/d/kart-telemetry/karting?orgId=1&kiosk&theme=dark&refresh=2s

# Writer settings
DECODER_ID=decoder-01
BATCH_SIZE=100
FLUSH_INTERVAL_SEC=5

# Paths
RAW_CAPTURE_PATH=services/decoder_ingest/raw_capture.log
FALLBACK_PATH=services/decoder_ingest/influx_fallback.ndjson
SNAPSHOT_PATH=services/decoder_ingest/session_snapshot.json
SNAPSHOT_INTERVAL_SEC=10

# Lap / dashboard
TRANSPONDER_PREFIX_LEN=12
LAP_NOISE_THRESHOLD_SEC=10
LAP_TIMER_TIMEOUT_SEC=120
LAP_MAX_LAP_TIME_SEC=600
CAR_NUMBER_MAP=14021124C877:11,140215359577:12,140210B98377:13,148210E3C477:14,140201B81B77:15,140210D7E877:16,140211084277:17,140211241C77:18,140215494F77:19,140210998E77:20
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# AmbRC/MyLaps: lap_sec = (tick2 - tick1) / DECODER_TICK_HZ.
# Wire ticks are ASCII HEX digits (e.g. "53297837" → 0x53297837), NOT decimal.
# Default 256000 matches the documented divisor. Do NOT set ~14250 — that comes
# from wrongly treating the hex ASCII as a base-10 integer.
# Leave blank (DECODER_TICK_HZ=) only for debug wall-clock fallback.
DECODER_TICK_HZ=256000

# Session archival: on every reset (manual or idle-timeout), the current
# session's lap data is archived to InfluxDB before being cleared.
# AUTO_ARCHIVE_IDLE_SEC is a safety net only (not a heat-boundary detector) —
# it force-archives+resets after this many seconds of total inactivity, so a
# forgotten "current session" doesn't silently bleed into the next day.
AUTO_ARCHIVE_IDLE_SEC=1800
# When every car's lap timer is already frozen (timeout / decoder down) AND
# idle exceeds this many seconds, archive immediately — so a finished heat
# lands in 場次紀錄 without waiting for the full IDLE timeout above.
AUTO_ARCHIVE_ALL_FROZEN_SEC=300

# Set to a file path to enable unconditional raw-trailing-byte logging of
# every passing frame (not just unrecognized packets). Used only during a
# calibration capture to determine the decoder's tick encoding; leave blank
# in normal operation.
PASSING_CALIBRATION_PATH=

# Web layer (services/webapp): auth, SQLite, AI coach
SQLITE_PATH=services/webapp/kpp.sqlite3
SECRET_KEY=change-me-to-a-random-64-char-hex-string
# true = skip real Google OAuth and log in as a fixed dev user (never enable in production)
AUTH_DEV_BYPASS=false
AVATAR_UPLOAD_DIR=uploads/avatars
# IANA timezone used to render timestamps (bound_at/started_at/ended_at) in
# the UI. Stored timestamps are always UTC; this only affects display.
DISPLAY_TIMEZONE=Asia/Taipei

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.example/api/auth/google/callback

AI_PROVIDER=ExpTech
AI_BASE_URL=https://ai.exptech.dev/v1
AI_API_KEY=
AI_DEFAULT_MODEL=auto
AI_KNOWN_MODELS=auto,ornith-1.0-35b,ornith-1.0-35b-a3b,ornith-1.0-9b
AI_AUTO_CHAT_MODEL=ornith-1.0-35b
AI_FAST_MODEL=ornith-1.0-9b

# Logging
LOG_LEVEL=INFO
