# Decoder TCP source (USR-W610)
# 單一 decoder 用 DECODER_HOST/DECODER_PORT（搭配下面 Writer settings 的
# DECODER_ID）。多台 decoder（例如同一起跑線硬體備援）改用 DECODERS，
# 格式 host:port:decoder_id 逗號分隔，設定後會取代 DECODER_HOST/PORT/ID：
# DECODERS=10.10.100.254:8899:decoder-01,10.10.100.253:8899:decoder-02
DECODER_HOST=10.10.100.254
DECODER_PORT=8899

# Reconnect backoff
RECONNECT_INITIAL_SEC=1
RECONNECT_MAX_SEC=30

# InfluxDB (required unless --dry-run)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-token-here
INFLUX_ORG=your-org
INFLUX_BUCKET=decoder

# Writer settings
DECODER_ID=decoder-01
BATCH_SIZE=100
FLUSH_INTERVAL_SEC=5

# Paths
RAW_CAPTURE_PATH=services/decoder_ingest/raw_capture.log
FALLBACK_PATH=services/decoder_ingest/influx_fallback.ndjson
SNAPSHOT_PATH=services/decoder_ingest/session_snapshot.json
SNAPSHOT_INTERVAL_SEC=10

# Lap / dashboard
TRANSPONDER_PREFIX_LEN=12
LAP_NOISE_THRESHOLD_SEC=10
LAP_TIMER_TIMEOUT_SEC=120
LAP_MAX_LAP_TIME_SEC=600
CAR_NUMBER_MAP=140211241C5E:18,140210D7E85E:19,140215494F5E:16,140210998E5E:14,140210E3C45E:20,14021124C85F:11,1402101B81B5E:15,140210B9835E:13,14021535955E:12
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Logging
LOG_LEVEL=INFO
