# Decoder TCP source (USR-W610)
# 單一 decoder 用 DECODER_HOST/DECODER_PORT（搭配下面 Writer settings 的
# DECODER_ID）。多台 decoder（例如同一起跑線硬體備援）改用 DECODERS，
# 格式 host:port:decoder_id 逗號分隔，設定後會取代 DECODER_HOST/PORT/ID：
# DECODERS=10.10.100.254:8899:decoder-01,10.10.100.253:8899:decoder-02
#
# 本機（與 W610 同 LAN）：用 W610 的區網 IP，延遲最低
# 遠端 tailnet 裝置：用 MagicDNS（需先在 Windows 閘道跑 scripts/setup-tailscale-w610.ps1）
# DECODER_HOST=usrw610.tail227cf2.ts.net
DECODER_HOST=10.10.100.254
DECODER_PORT=8899

# Reconnect backoff
RECONNECT_INITIAL_SEC=1
RECONNECT_MAX_SEC=30

# InfluxDB (required unless --dry-run)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-token-here
INFLUX_ORG=your-org
INFLUX_BUCKET=decoder

# Writer settings
DECODER_ID=decoder-01
BATCH_SIZE=100
FLUSH_INTERVAL_SEC=5

# Paths
RAW_CAPTURE_PATH=services/decoder_ingest/raw_capture.log
FALLBACK_PATH=services/decoder_ingest/influx_fallback.ndjson
SNAPSHOT_PATH=services/decoder_ingest/session_snapshot.json
SNAPSHOT_INTERVAL_SEC=10

# Lap / dashboard
TRANSPONDER_PREFIX_LEN=12
LAP_NOISE_THRESHOLD_SEC=10
LAP_TIMER_TIMEOUT_SEC=120
LAP_MAX_LAP_TIME_SEC=600
CAR_NUMBER_MAP=140210B98368:13,140210E3C468:14,14021124C868:11,140201B81B68:15
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Decoder tick precision (leave DECODER_TICK_HZ blank to keep lap-time math on
# the existing received_at-based calculation). Once a diagnostic capture
# (see PASSING_CALIBRATION_PATH below) confirms the trailing-payload tick
# encoding, set DECODER_TICK_HZ to the confirmed tick rate (e.g. 1000) and
# adjust the byte offset/length if needed.
DECODER_TICK_HZ=
DECODER_TICK_BYTE_OFFSET=1
DECODER_TICK_BYTE_LEN=3

# Session archival: on every reset (manual or idle-timeout), the current
# session's lap data is archived to InfluxDB before being cleared.
# AUTO_ARCHIVE_IDLE_SEC is a safety net only (not a heat-boundary detector) —
# it force-archives+resets after this many seconds of total inactivity, so a
# forgotten "current session" doesn't silently bleed into the next day.
AUTO_ARCHIVE_IDLE_SEC=1800

# Set to a file path to enable unconditional raw-trailing-byte logging of
# every passing frame (not just unrecognized packets). Used only during a
# calibration capture to determine the decoder's tick encoding; leave blank
# in normal operation.
PASSING_CALIBRATION_PATH=

# Logging
LOG_LEVEL=INFO
