// --- 上傳路徑（二選一）---
// 熱點 / 有網際網路：TELEMETRY_USE_HTTP=1（走 Cloudflare → chuck webapp）
// 家裡 LAN 直打 Pi：TELEMETRY_USE_HTTP=0 + SERVER_IP / SERVER_PORT
#ifndef TELEMETRY_USE_HTTP
#define TELEMETRY_USE_HTTP 1
#endif

#ifndef INGEST_FRAME_URL
#define INGEST_FRAME_URL \
  "https://chuck.dctggest.filegear-sg.me/api/telemetry/frame-ingest"
#endif

#ifndef INGEST_TOKEN
// 與伺服器 .env TELEMETRY_INGEST_TOKEN 相同
#define INGEST_TOKEN "kpp-telemetry-ingest-token-change-me"
#endif

#ifndef SERVER_IP
#define SERVER_IP "192.168.0.105"
#endif

#ifndef SERVER_PORT
#define SERVER_PORT 9500
#endif

