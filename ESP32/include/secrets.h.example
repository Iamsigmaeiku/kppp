#pragma once
// 複製成 secrets.h（已在 .gitignore）後填入真實值。
//   copy include\secrets.h.example include\secrets.h
//
// Hybrid dual-gps（env:esp32-dual-gps）仍走 INGEST_URL，不要加 INFLUX_*。
// 燒錄 esp32-dual-gps 前務必拔掉 UART0 上的 M10 TX/RX。

#ifndef WIFI_SSID
#define WIFI_SSID "iPhone"
#endif

#ifndef WIFI_PASS
#define WIFI_PASS "CHANGE_ME"
#endif

// 備援（預設同主網 = 只連一個 AP；若要加第二個再改）
#ifndef WIFI_SSID2
#define WIFI_SSID2 WIFI_SSID
#endif

#ifndef WIFI_PASS2
#define WIFI_PASS2 WIFI_PASS
#endif

// 區網優先（與 Pi 同 LAN 才撐得住 25Hz ring）；出外再靠 FALLBACK
#ifndef INGEST_URL
#define INGEST_URL "http://192.168.0.105:5000/api/telemetry/ingest"
#endif

// 可選：INGEST_URL 連不上時改打公開站
#ifndef INGEST_URL_FALLBACK
#define INGEST_URL_FALLBACK \
  "https://chuck.dctggest.filegear-sg.me/api/telemetry/ingest"
#endif

// 必須與伺服器 .env 的 TELEMETRY_INGEST_TOKEN 一致
#ifndef INGEST_TOKEN
#define INGEST_TOKEN "kpp-telemetry-ingest-token-change-me"
#endif

#ifndef DEVICE_ID
#define DEVICE_ID "esp32-kart-01"
#endif

// 可選：對應車號
#ifndef CAR_ID
#define CAR_ID ""
#endif
